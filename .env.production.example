# Production Environment Variables Example
# Kopyalayarak .env.production isimli bir dosya oluşturun ve değerleri doldurun.

# Database Settings
POSTGRES_USER=jetis_admin
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=jetis_production

# JWT Authentication
JWT_SECRET=generate_a_very_long_random_string_here_for_production

# API Settings (Opsiyonel)
PORT=3000

# CORS — virgülle ayrılmış allowed origin listesi
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Vite Web Environment Variables (Frontend)
# Bu değerler Docker build sırasında --build-arg olarak Vite'a iletilir.
VITE_API_URL=https://api.yourdomain.com
VITE_SOCKET_URL=https://api.yourdomain.com
